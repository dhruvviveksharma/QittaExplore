# Required env for the Flask backend on kl-remote.
# Copy this file to .env (gitignored) and fill in real values.
# Format: KEY=VALUE with no spaces around `=` (systemd EnvironmentFile parses
# this same file format).

# JWT signing secret for any auth tokens the app issues.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me

# Admin password gate (if/when used by the app).
ADMIN_PASS=change-me

# LLM provider API key used by services/llm.py.
API_KEY=change-me

# Directory of the local Qiita checkout the backend reads from.
# On kl-remote this is the repo root: /home/kl-user/QittaExplore
DIRECTORY=/home/kl-user/QittaExplore

# Postgres connection used by services/study_service.py.
# In production on kl-remote, the host/port resolve to barnacle's Postgres
# through the SSH -L tunnel set up by the systemd barnacle-tunnel.service.
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=qiita_test
PG_USER=postgres
PG_PASSWORD=change-me
