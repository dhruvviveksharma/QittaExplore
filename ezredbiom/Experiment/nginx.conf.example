# Drop-in nginx config for lab deployment.
# Adjust server_name, SSL certificate paths, and static file root as needed.

server {
    listen 80;
    server_name your-lab-server.example.com;
    # Redirect HTTP → HTTPS
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name your-lab-server.example.com;

    ssl_certificate     /etc/letsencrypt/live/your-lab-server.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/your-lab-server.example.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    # ── Static frontend files (served directly by nginx, no Flask needed) ──────
    root /path/to/qiita-web/ezredbiom/Experiment/frontend;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # ── API proxy ──────────────────────────────────────────────────────────────
    location ~ ^/(api|auth)/ {
        proxy_pass         http://127.0.0.1:5001;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   Authorization $http_authorization;
        proxy_pass_header  Authorization;
        proxy_read_timeout 310s;   # slightly above Gunicorn --timeout 300
        proxy_send_timeout 310s;
    }

    # ── SSE streams: disable buffering so tokens reach the browser immediately ─
    location ~ ^/api/.*/stream$ {
        proxy_pass            http://127.0.0.1:5001;
        proxy_set_header      Host $host;
        proxy_set_header      X-Real-IP $remote_addr;
        proxy_set_header      Authorization $http_authorization;
        proxy_pass_header     Authorization;
        proxy_buffering       off;
        proxy_cache           off;
        add_header            X-Accel-Buffering no;
        proxy_read_timeout    310s;
        proxy_send_timeout    310s;
        chunked_transfer_encoding on;
    }
}
