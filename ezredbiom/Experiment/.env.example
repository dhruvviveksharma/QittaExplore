# Copy this file to .env and fill in the values before starting the server.

# ── Qiita ─────────────────────────────────────────────────────────────────────
API_KEY=<your-LLM-API-key>
QIITA_CONFIG_FP=/path/to/qiita_config.cfg
QIITA_EXPERIMENT_DB_PATH=~/.qiita-experiment/projects.db

# ── Auth ───────────────────────────────────────────────────────────────────────
# REQUIRED — server will refuse to start without this set to a real value.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=<random-32+-char-secret>

# Comma-separated list of allowed CORS origins (no trailing slashes).
# In production, set this to your exact frontend URL.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Initial admin account (created on first boot if no users exist)
ADMIN_USER=admin
ADMIN_PASS=<initial-admin-password>

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5001
GUNICORN_WORKERS=4
