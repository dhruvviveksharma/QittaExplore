# Copy this file to ezredbiom/Experiment/.env and fill in real values.
# .env is gitignored — never commit it.

# ── REQUIRED ────────────────────────────────────────────────────────────────

# NRP-Nautilus LLM bearer token. Backend services/llm.py uses this to call
# https://ellm.nrp-nautilus.io/v1
API_KEY=

# JWT signing secret — rotate before deploy. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Admin password for whatever admin endpoints exist. The dev value is
# "test123" — DO NOT keep that in production.
ADMIN_PASS=

# ── OPTIONAL TUNING ─────────────────────────────────────────────────────────

# Cap on context size sent to the LLM per project / globally. Defaults are
# defined in run.py if omitted.
# PROJECT_CONTEXT_MAX_CHARS=
# GLOBAL_CONTEXT_MAX_CHARS=

# ── NOTE ON CORS ────────────────────────────────────────────────────────────
# The current run.py uses `CORS(app)` which allows any origin. In this
# deployment the app container is NOT published to the host — only nginx
# reaches it over the compose network — so the open CORS is harmless.
# If you ever publish app:5001 directly to the internet, edit run.py to
# restrict CORS first.
